{
    "name": "CureWhbyBook",
    "short_name": "CureWhbook",
    "manifest_version": 3,
    "version": "1.0.0",
    "description": "从武海笔院下载书籍",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "64": "icons/icon-64.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup/index.html",
        "default_icon": "icons/icon-64.png"
    },
    "background": {
        "service_worker": "background/service_worker.js",
        "type": "module"
    },
    "permissions": [
        "activeTab",
        "tabs",
        "debugger",
        "storage",
        "unlimitedStorage",
        "downloads"
    ],
    "host_permissions": [
        "https://wqbook.wqxuetang.com/deep/read/epub*",
        "https://wqbook.wqxuetang.com/deep/read/pdf*"
    ]
}